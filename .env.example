# Bibliophilarr local development environment template
# Copy to .env and adjust values for your machine.

# Runtime listener (used by Docker/local process launches)
ASPNETCORE_URLS=http://+:8787

# Optional PostgreSQL-backed runtime settings.
# Keep these unset to use the default SQLite local database.
# Preferred prefix for rename migration:
Bibliophilarr__Postgres__Host=localhost
Bibliophilarr__Postgres__Port=5432
Bibliophilarr__Postgres__User=readarr
Bibliophilarr__Postgres__Password=readarr
Bibliophilarr__Postgres__MainDb=bibliophilarr-main
Bibliophilarr__Postgres__LogDb=bibliophilarr-log
Bibliophilarr__Postgres__CacheDb=bibliophilarr-cache

# Compatibility prefix (still supported during migration):
Readarr__Postgres__Host=localhost
Readarr__Postgres__Port=5432
Readarr__Postgres__User=readarr
Readarr__Postgres__Password=readarr
Readarr__Postgres__MainDb=bibliophilarr-main
Readarr__Postgres__LogDb=bibliophilarr-log
Readarr__Postgres__CacheDb=bibliophilarr-cache

# npm launcher defaults (optional overrides)
BIBLIOPHILARR_OWNER=Swartdraak
BIBLIOPHILARR_REPO=Bibliophilarr
BIBLIOPHILARR_VERSION=latest

# Optional local automation tokens.
# Do not commit real tokens.
GITHUB_TOKEN=
NPM_TOKEN=

# Optional release telemetry variables (if used in your environment)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_URL=
